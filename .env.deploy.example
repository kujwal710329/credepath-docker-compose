# ===========================================
# SSH connection details for start.sh
# Copy to .env.deploy and fill in your values.
# .env.deploy is gitignored — never commit it.
#
# start.sh reads this file automatically if it exists,
# so you don't have to enter SSH details every time.
# ===========================================

# Staging EC2
STAGING_EC2_HOST=
STAGING_EC2_USER=ubuntu
STAGING_EC2_KEY_PATH=~/.ssh/credepath-staging.pem

# Production EC2
PROD_EC2_HOST=
PROD_EC2_USER=ubuntu
PROD_EC2_KEY_PATH=~/.ssh/credepath-prod.pem
