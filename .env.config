# ===========================================
# Non-sensitive configuration — committed to git.
# deploy.sh overrides env-specific values (NODE_ENV, bucket names, etc.)
# at deploy time based on the target environment (staging / production).
# start.sh overwrites this file for local dev runs.
# Sensitive secrets are stored in GitHub Environment secrets (CI/CD)
# or exported as shell env vars (local runs via start.sh).
# ===========================================

# -------------------------------------------
# ECR Image Config
# -------------------------------------------
ECR_REGISTRY=329103132150.dkr.ecr.ap-south-1.amazonaws.com
IMAGE_TAG=latest

# -------------------------------------------
# Environment
# -------------------------------------------
NODE_ENV=development

# -------------------------------------------
# Service Ports
# -------------------------------------------
FRONTEND_PORT=3000
BACKEND_PORT=5000
ML_SERVICE_PORT=8000
PORT=5000

# -------------------------------------------
# JWT Config
# -------------------------------------------
JWT_EXPIRES_IN=90d

# -------------------------------------------
# Email Config
# -------------------------------------------
SENDER_EMAIL=ujjwal@acrapath.com

# -------------------------------------------
# AWS Config
# -------------------------------------------
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=credepath-prod

# -------------------------------------------
# ML Service Config
# -------------------------------------------
PINECONE_ENV=us-east-1
PINECONE_INDEX_NAME=acrapath-job-recommendations
SKIP_API_KEY_CHECK=false
ML_API_HOST=0.0.0.0
ML_API_PORT=8000

# -------------------------------------------
# Internal Service URLs (Docker network)
# -------------------------------------------
JOB_RECOMMENDER_API_URL=http://jobs-recommender:8000

# -------------------------------------------
# Frontend Public URLs
# -------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_S3_BASE_URL=https://credepath-prod.s3.ap-south-1.amazonaws.com
