# ===========================================
# Static, environment-agnostic config — committed to git.
# Do NOT put environment-specific values here (NODE_ENV, bucket names,
# image names, etc.) — those all live in deploy.sh under the relevant
# staging / production case block.
# Secrets are stored in GitHub Environment secrets (CI/CD) or exported
# as shell env vars (local runs via start.sh).
# ===========================================

# -------------------------------------------
# ECR
# -------------------------------------------
ECR_REGISTRY=329103132150.dkr.ecr.ap-south-1.amazonaws.com

# -------------------------------------------
# Service Ports
# -------------------------------------------
FRONTEND_PORT=3000
BACKEND_PORT=5000
ML_SERVICE_PORT=8000
PORT=5000

# -------------------------------------------
# JWT Config
# -------------------------------------------
JWT_EXPIRES_IN=90d

# -------------------------------------------
# Email Config
# -------------------------------------------
SENDER_EMAIL=ujjwal@acrapath.com

# -------------------------------------------
# AWS Config
# -------------------------------------------
AWS_REGION=ap-south-1

# -------------------------------------------
# ML Service Config
# -------------------------------------------
PINECONE_ENV=us-east-1
ML_API_HOST=0.0.0.0
ML_API_PORT=8000

# -------------------------------------------
# Internal Service URLs (Docker network)
# -------------------------------------------
JOB_RECOMMENDER_API_URL=http://jobs-recommender:8000
